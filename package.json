{
  "name": "hopeai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode local",
    "deploy:managed": "bash scripts/deploy-managed.sh",
    "deploy:managed:db": "bash scripts/deploy-managed.sh --db-only",
    "deploy:managed:functions": "bash scripts/deploy-managed.sh --functions-only",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:functions": "supabase functions serve --env-file supabase/.env.local",
    "supabase:cron-tick": "bash scripts/cron-tick.sh",
    "test:scheduling": "node scripts/test-sequence-scheduling.mjs",
    "setup:local-env": "bash scripts/setup-local-env.sh",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && cap sync",
    "cap:ios": "npm run build && cap sync ios && cap open ios",
    "cap:android": "npm run build && cap sync android && cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@supabase/supabase-js": "^2.106.2",
    "@twilio/voice-sdk": "^2.18.3",
    "axios": "^1.16.1",
    "capacitor-voice-recorder": "^7.0.6",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12"
  }
}
